{
  "enableOnDesktop": false,
  "events": {
    "complete": {
      "command": true,
      "notification": true,
      "sound": true
    },
    "error": {
      "command": true,
      "notification": true,
      "sound": true
    },
    "permission": {
      "command": true,
      "notification": true,
      "sound": true
    },
    "question": {
      "command": true,
      "notification": true,
      "sound": true
    },
    "subagent_complete": {
      "command": true,
      "notification": false,
      "sound": false
    },
    "user_cancelled": {
      "command": true,
      "notification": false,
      "sound": false
    }
  },
  "linux": {
    "grouping": true
  },
  "messages": {
    "complete": "OpenCode session finished: {sessionTitle}",
    "error": "OpenCode hit an error: {sessionTitle}",
    "permission": "OpenCode needs permission: {sessionTitle}",
    "question": "OpenCode has a question: {sessionTitle}",
    "subagent_complete": "OpenCode subagent finished: {sessionTitle}",
    "user_cancelled": "OpenCode session cancelled: {sessionTitle}"
  },
  "notification": true,
  "showIcon": true,
  "showProjectName": true,
  "showSessionTitle": true,
  "sound": true,
  "sounds": {
    "complete": null,
    "error": null,
    "permission": null,
    "question": null,
    "subagent_complete": null,
    "user_cancelled": null
  },
  "suppressWhenFocused": false,
  "timeout": 5,
  "volumes": {
    "complete": 1,
    "error": 1,
    "permission": 1,
    "question": 1,
    "subagent_complete": 1,
    "user_cancelled": 1
  }
}
